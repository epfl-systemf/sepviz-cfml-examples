{
  "scripts": {
    "gen:proofs:example": "./scripts/gen_proofs_example.sh",
    "gen:proofs:lp": "./scripts/gen_proofs_lp.sh",
    "gen:proofs": "run-s gen:proofs:example gen:proofs:lp",
    "inject": "./scripts/inject.sh",
    "gen:parser": "npx peggy --format es -o src/parser.js src/assets/sep.g",

    "prepare": "run-s gen:proofs inject gen:parser",

    "dev": "run-s prepare vite",
    "vite:build": "vite build",
    "build": "run-s prepare vite:build",
    "preview": "vite preview",
    "test": "vitest"
  },
  "devDependencies": {
    "@types/node": "^24.10.0",
    "@typescript-eslint/eslint-plugin": "^8.46.3",
    "@typescript-eslint/parser": "^8.46.3",
    "eslint": "^9.39.1",
    "lodash": "^4.17.21",
    "npm-run-all": "^4.1.5",
    "peggy": "^5.0.6",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3",
    "vite": "^7.2.1",
    "vitest": "^4.0.15"
  },
  "dependencies": {
    "d3": "^7.9.0",
    "d3-graphviz": "^5.6.0",
    "js-yaml": "^4.1.0"
  }
}
